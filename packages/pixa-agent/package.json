{
  "name": "pixa-agent",
  "displayName": "Pixa Agent",
  "description": "AI coding agent for Pixa IDE — plans, edits, and runs tasks in your workspace with your approval.",
  "version": "0.5.0",
  "publisher": "pixa",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pixa",
          "title": "Pixa Agent",
          "icon": "media/pixa.svg"
        }
      ]
    },
    "views": {
      "pixa": [
        {
          "type": "webview",
          "id": "pixa.chat",
          "name": "Agent"
        }
      ]
    },
    "commands": [
      {
        "command": "pixa.setApiKey",
        "title": "Pixa: Set OpenRouter API Key"
      },
      {
        "command": "pixa.newSession",
        "title": "Pixa: New Agent Session"
      },
      {
        "command": "pixa.rebuildSemanticIndex",
        "title": "Pixa: Rebuild Semantic Search Index"
      },
      {
        "command": "pixa.debugSemanticSearch",
        "title": "Pixa: Debug Semantic Search (test query, no LLM)"
      },
      {
        "command": "pixa.runRecallBenchmark",
        "title": "Pixa: Run Retrieval Recall Benchmark"
      }
    ],
    "configuration": {
      "title": "Pixa Agent",
      "properties": {
        "pixa.defaultModel": {
          "type": "string",
          "default": "nemotron-free",
          "description": "Model id from models.json used by default."
        },
        "pixa.maxTokens": {
          "type": "number",
          "default": 8192,
          "description": "Maximum completion tokens per request. Lower this if you hit OpenRouter 402 'requires more credits' errors on a low-balance/free account."
        },
        "pixa.mcpServers": {
          "type": "object",
          "default": {},
          "markdownDescription": "MCP servers whose tools the agent can use. Example: `{ \"filesystem\": { \"command\": \"npx\", \"args\": [\"-y\", \"@modelcontextprotocol/server-filesystem\", \"./\"] } }`. Reload the window after changing.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "command"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
