# OpenRouter key held server-side — never sent to the extension.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional. Comma-separated bearer tokens the extension must present
# (Authorization: Bearer <token>). Leave empty to disable auth for local dev.
GATEWAY_TOKENS=dev-token-1,dev-token-2

# Optional alternative/addition: path to a JSON array of token strings.
# GATEWAY_TOKENS_FILE=./tokens.json

PORT=8080
