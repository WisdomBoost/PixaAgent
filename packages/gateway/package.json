{
    "name": "pixa-gateway",
    "version": "0.1.0",
    "description": "Stateless BYOK inference gateway for the Pixa VS Code extension — proxies chat to OpenRouter using each client's own API key.",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "start": "tsx src/server.ts",
        "dev": "tsx --watch src/server.ts",
        "mock-upstream": "tsx src/mock-upstream.ts",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "start:built": "node dist/server.js"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "better-sqlite3": "^11.8.1",
        "dotenv": "^16.6.1",
        "express": "^4.22.2"
    },
    "directories": {
        "test": "test"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.12",
        "@types/express": "^5.0.6",
        "@types/node": "^20.19.43",
        "tsx": "^4.23.1",
        "typescript": "^5.9.3"
    }
}