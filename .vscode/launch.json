{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Pixa Agent",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/pixa-agent",
        "--disable-extension=PIXAFLIP.pixa-agent"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/pixa-agent/dist/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    }
  ]
}
